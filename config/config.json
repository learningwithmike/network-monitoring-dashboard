{
  "monitoring": {
    "checkInterval": 300,
    "cpuThreshold": 80,
    "memoryThreshold": 85,
    "diskThreshold": 90,
    "networkLatencyThreshold": 100
  },
  "alerts": {
    "enableEmailAlerts": false,
    "emailTo": "your-email@example.com",
    "enableLogAlerts": true,
    "logPath": "./logs"
  },
  "monitoring_targets": {
    "localComputer": "localhost",
    "remoteServers": [
      "192.168.1.1",
      "192.168.1.2"
    ],
    "monitoredProcesses": [
      "svchost",
      "explorer"
    ]
  }
}